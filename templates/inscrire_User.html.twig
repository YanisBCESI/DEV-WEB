{% extends "base.html.twig" %}
{% block link %} <link rel="stylesheet" href="/assets/style_inscription_user.css"> {% endblock %}
{% block script %} <script src="/assets/script_signup.js"></script> {% endblock %}
{% block title %}Inscription Utilisateur - Stage4all{% endblock %}

{% block content %}
<div class="Contenu_page">
    <section class="u_block1">
        <h1>Créer un compte</h1>

        <form action="index.php?uri=account_created script_signup" method="post" enctype="multipart/form-data" onsubmit="return checkFor(this);">
            <div class="u_div">
                <input name="lastname" type="text" placeholder="Nom" required class="u_input u_lastname" pattern="/^[A-Za-z-]{1,20}$/">
                <input name="surname" type="text" placeholder="Prénom" required class="u_input" pattern="/^[A-Za-z-]{1,20}$/">
            </div>
            <div class="u_div">
                <select name="genre" required>
                <option value="" disabled selected>Choisissez le genre de l'étudiant</option>
                <option value="femme">Madame</option>
                <option value="homme">Monsieur</option>
                <option value="autre">Autre</option>
                </select>

                <select name="role" required class="u_input">
                <option value="etudiant" selected>Étudiant</option>
                <option value="alternant">Alternant</option>
                </select>
            </div>

            <input name="email" type="email" placeholder="e-mail / login" required class="u_input" pattern="[-A-Za-z0-9!#$%&'*+/=?^_`{|}~]+(?:\.[-A-Za-z0-9!#$%&'*+/=?^_`{|}~]+)*@(?:[A-Za-z0-9](?:[-A-Za-z0-9]*[A-Za-z0-9])?\.)+[A-Za-z0-9](?:[-A-Za-z0-9]*[A-Za-z0-9])?">
            <input name="password" type="password" placeholder="Mot de passe" required class="u_input">
            <input name="password_confirm" type="password" placeholder="Confirmation" required class="u_input">
            <button class="b2 u_button" type="submit">Créer mon compte</button>
            <a href="?uri=connect">Vous avez déjà un compte ?</a>
        </form>
    </section>
</div>
{% endblock %}
