{%  extends 'base.html.twig' %}

{% block title %}Accueil - Stage4all{% endblock %}

{% block content %}

    <div class="Presentation">
        <img src="/assets/images/Fond_accueil.jpg" alt="Fond_page" class="Fond_page">
        <div class="Titre_presentation">
            <h1 class="Nom_site Nom_presentation">Stage 4 all</h1>
        </div>
        <h2>La recherche de stage facile pour tous</h2>
        <a href="?uri=offres"><button class="b1" type="button">Commencer</button></a>
    </div>
    <div class="Offres">
        <h1>Quelques Offres</h1>
        <div class="nav_page">
            <button class="fleche_gauche fleche" id="fleche_gauche1" onclick="scrollListe1(-70)"><</button>
            <div class="Liste_offres" id="liste1">
                {% if latest_offers is defined and latest_offers is not empty %}
                    {% for offre in latest_offers %}
                        <div class="Offre">
                            <h2>{{ offre.titre|default('Titre Offre') }}</h2>
                            <p class="Texte_sub_class">{{ offre.description_offre|default('Phrase du stage')|striptags|slice(0, 110) }}{% if offre.description_offre is defined and offre.description_offre|length > 110 %}...{% endif %}</p>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="Offre">
                        <h2>Titre Offre</h2>
                        <p>Phrase du stage</p>
                    </div>
                {% endif %}
                <!--système d'ajout de pages d'Articles-->
                <button class="fleche_droite fleche" id="fleche_droite1" onclick="scrollListe1(70)">></button>
            </div>
        </div>
    </div>
    <div class="Actualite">
        <div class="Article">
            <h2>Titre article</h2>
            <p>Texte de l'article</p>
            <button class="b2">Consulter</button>
        </div>
        <!--système d'ajout de pages d'Articles-->
    </div>
    <div class="Conseils">
        <div class="nav_page">
            {% set liste_conseils = conseils %}
            <button class="fleche_gauche fleche" id="fleche_gauche3" onclick="scrollListe3(-70)"><</button>
            <div class="Liste_conseils liste" id="liste3">
            {% for conseil in liste_conseils %}
                <div class="Conseil">
                    <h2 class="Titre_sub_class">{{ conseil.Titre }}</h2>
                    <form action="?uri=conseil&id_offre={{conseil.id}}" method="POST">
                        <input type="hidden" name="conseil_id" value="{{conseil.id}}">
                        <button class="b2" type="submit">Consulter</button>
                    </form>
                </div>
            {% endfor %}
            </div>
            <button class="fleche_droite fleche" id="fleche_droite3" onclick="scrollListe3(70)">></button>
        </div>
    </div>
{% endblock %}