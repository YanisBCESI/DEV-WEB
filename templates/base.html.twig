<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Stage4all{% endblock %}</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="stylesheet" href="/assets/style_index.css">
    <link rel="icon" type="image/png" href="/assets/images/icon.png">
    {% block link %} <link> {% endblock %}
    {% block script %} <script></script> {% endblock %}
    {% block styles %}{% endblock %}
</head>
<body>
    <header>
        <div class="Titre">
            <img class="Logo" src="/assets/images/icon.png" alt="logo de S4A">
            <h1 class="Nom_site">Stage 4 All</h1>
        </div>
        <div class="Bouton_menu_burger" id="burger">
            <span class="Barre_menu_burger"></span>
            <span class="Barre_menu_burger"></span>
            <span class="Barre_menu_burger"></span>
        </div>

        <nav class="nav_PC">
            <a href="/"><img class="Logo_nav" alt="Accueil" src="/assets/images/Accueil.png">Accueil</a>
            <span></span>
            <a href="?uri=offres"><img class="Logo_nav" alt="Offres" src="/assets/images/Offre.png">Offres</a>
            <span></span>
            <a href="?uri=conseils"><img class="Logo_nav" alt="Conseil" src="/assets/images/Conseil.png">Conseil</a>
            <span></span>
            <a href="#"><img class="Logo_nav" alt="Support" src="/assets/images/Support.png">Support</a>
        </nav>

        <div class="header-actions">
            {% if is_management_logged_in %}
                <a class="b2 header-admin-link" href="?uri=admin_students">Etudiants</a>
            {% endif %}

            {% if is_student_logged_in %}
                <a class="header-icon-link" href="?uri=wishlist" aria-label="Ma wishlist">
                    <img class="header-icon" src="{{ wishlist_icon_path }}" alt="wishlist">
                </a>
            {% endif %}

            <a class="header-icon-link" href="{% if is_student_logged_in %}?uri=student_profile{% elseif is_management_logged_in %}?uri=admin_students{% else %}?uri=connect{% endif %}" aria-label="{% if is_student_logged_in %}Mon profil etudiant{% elseif is_admin_logged_in %}Gestion des comptes{% elseif is_pilot_logged_in %}Gestion de mes etudiants{% else %}Se connecter{% endif %}">
                <img class="header-icon" src="/assets/images/compte.png" alt="compte">
            </a>
        </div>
    </header>

    <main class="contenu_page {% block body_class %}{% endblock %}">
        {% block content %}{% endblock %}
    </main>

    <footer>
        <h2>Stage 4 All</h2>
        <a class="footer-link" href="?uri=mentions_legales"><h2>Mentions legales</h2></a>
        <a class="footer-link" href="#"><h2>Cookies</h2></a>
        <a class="footer-link" href="#"><h2>Besoin d'Aide ?</h2></a>
        <div class="Follow_us"><h2>Suivez nous sur :&nbsp;</h2><a><img class="Logo_connexion" src="/assets/images/Insta.png" alt="Insta"></a><a><img class="Logo_connexion" src="/assets/images/X.png" alt="X"></a><a><img class="Logo_connexion" src="/assets/images/Youtube.png" alt="Youtube"></a></div>
    </footer>

    {% block scripts %}{% endblock %}
</body>
</html>
