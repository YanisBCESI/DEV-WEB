{% extends 'base.html.twig' %}

{% block title %}Offres - Stage4all{% endblock %}

{% block styles %}
<style>
    .offres-page {
        width: min(1200px, calc(100% - 3rem));
        margin: 3rem auto 4rem;
        text-align: center;
    }

    .offres-page h1 {
        margin-bottom: 0.75rem;
        font-size: clamp(2rem, 4vw, 3rem);
    }

    .offres-intro {
        margin: 0 0 2.5rem;
        color: #4f3f59;
        font-size: 1.05rem;
    }

    .offres-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
    }

    .offre-card,
    .offres-empty {
        background: #e7bdfa;
        border: 4px solid #a812ed;
        border-radius: 2.5rem;
        box-sizing: border-box;
    }

    .offre-card {
        min-height: 420px;
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        text-align: center;
    }

    .offre-card h2 {
        margin-bottom: 1rem;
        font-size: 1.8rem;
    }

    .offre-card-body {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .offre-card-body p {
        margin: 0;
        line-height: 1.5;
    }

    .offre-description {
        margin-top: auto;
        padding-top: 1.5rem;
    }

    .offre-actions {
        margin-top: 1.5rem;
    }

    .offre-actions form {
        margin: 0;
    }

    .offres-empty {
        max-width: 420px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .offres-empty p {
        margin: 0 0 1.5rem;
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        .offres-page {
            width: min(100% - 1.5rem, 100%);
            margin: 2rem auto 3rem;
        }

        .offre-card {
            min-height: 360px;
            border-radius: 2rem;
            padding: 1.5rem 1.25rem;
        }
    }
</style>
{% endblock %}

{% block content %}
<section class="offres-page">
    <h1>Liste des offres</h1>
    <p class="offres-intro">Retrouve ici les offres disponibles dans un affichage clair et cohérent avec Stage4All.</p>

    {% set liste_offres = offres|default([]) %}

    {% if liste_offres is empty %}
        <div class="offres-empty">
            <p>Aucune offre disponible pour le moment.</p>
            <a class="b2" href="/">Retour à l'accueil</a>
        </div>
    {% else %}
        <div class="offres-grid">
            {% for offre in liste_offres %}
                <article class="offre-card">
                    <div class="offre-card-body">
                        <h2>{{ offre.titre|default('Titre Offre') }}</h2>

                        <p>{{ offre.nom_entreprise|default('Entreprise non précisée') }}</p>
                        <p>{{ offre.type_contrat|default('Contrat non précisé') }}</p>
                        <p>{{ offre.localisation|default('Localisation non précisée') }}</p>

                        <p class="offre-description">
                            {{ offre.description|default('Phrase du stage')|striptags|slice(0, 180) }}{% if offre.description is defined and offre.description|length > 180 %}...{% endif %}
                        </p>
                    </div>

                    <div class="offre-actions">
                        <form action="/wishlist/ajouter" method="POST">
                            <input type="hidden" name="offre_id" value="{{ offre.id }}">
                            <button class="b2" type="submit">Ajouter à ma wishlist</button>
                        </form>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>
{% endblock %}
