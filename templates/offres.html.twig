{% extends 'base.html.twig' %}

{% block title %}Offres - Stage4all{% endblock %}

{% block content %}
<main>
    <h1>Liste des offres</h1>

    {% if offres is empty %}
        <p>Aucune offre disponible pour le moment.</p>
    {% else %}
        {% for offre in offres %}
            <form action="/wishlist/ajouter" method="POST">
                <input type="hidden" name="offre_id" value="{{ offre.id }}">
                <button type="submit">Ajouter à ma wishlist</button>
            </form>

            <div class="offre">
                <h2>{{ offre.titre }}</h2>

                <p><strong>Entreprise :</strong> {{ offre.nom_entreprise }}</p>
                <p><strong>Type de contrat :</strong> {{ offre.type_contrat }}</p>
                <p><strong>Secteur :</strong> {{ offre.secteur }}</p>
                <p><strong>Localisation :</strong> {{ offre.localisation }}</p>
                <p><strong>Statut :</strong> {{ offre.statut }}</p>

                <p><strong>Description :</strong><br>{{ offre.description|nl2br }}</p>
                <p><strong>Compétences :</strong><br>{{ offre.competences|nl2br }}</p>

                <p>
                    <strong>Rémunération :</strong>
                    {{ offre.remuneration ?? 'Non précisée' }}
                </p>

                <p>
                    <strong>Date de début :</strong>
                    {{ offre.date_debut ?? 'Non précisée' }}
                </p>

                <p>
                    <strong>Date de publication :</strong>
                    {{ offre.created_at }}
                </p>
            </div>
            <hr>
        {% endfor %}
    {% endif %}
</main>
{% endblock %}