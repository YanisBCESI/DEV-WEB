{% extends 'base.html.twig' %}

{% block title %}Mes candidatures - Stage4all{% endblock %}

{% block link %}
    <link rel="stylesheet" href="/assets/style_admin_pilots.css">
    <link rel="stylesheet" href="/assets/style_admin_students.css">
    <link rel="stylesheet" href="/assets/style_student_candidatures.css">
{% endblock %}

{% block content %}
<section class="admin-pilots-page">

    <div class="admin-pilots-hero">
        <div>
            <h1>Mes candidatures</h1>
            <p>Retrouve ici toutes les offres auxquelles tu as postulé.</p>
        </div>
    </div>

    <section class="admin-panel">
        <div class="admin-panel-header">
            <div>
                <h2>Liste des candidatures</h2>
                <p class="admin-panel-subtitle">Suivi de tes candidatures envoyées.</p>
            </div>
            <span class="admin-count">
                {{ candidatures|length }} candidature{{ candidatures|length != 1 ? 's' : '' }}
            </span>
        </div>

        {% if candidatures is empty %}
            <p class="admin-empty">
                Tu n'as encore postulé à aucune offre.
            </p>
        {% else %}
            <div class="admin-table-wrapper">
                <table class="admin-pilots-table student-management-table">
                    <thead>
                        <tr>
                            <th>Offre</th>
                            <th>Entreprise</th>
                            <th>Contrat</th>
                            <th>Description</th>
                            <th>Date</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for c in candidatures %}
                            <tr>
                                <td>{{ c.offre_titre }}</td>
                                <td>{{ c.entreprise_nom }}</td>
                                <td>{{ c.type_contrat }}</td>
                                <td class="candidature-description">
                                    {{ c.description_offre|slice(0, 80) ~ '...' }}
                                </td>
                                <td>{{ c.date_candidature|date("d/m/Y") }}</td>
                                <td>
                                    <span class="status status-{{ c.statut }}">
                                        {{ c.statut }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
</section>
{% endblock %}